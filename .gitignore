# Python/cache files
**/__pycache__/
*.pyc

# Virtual environments
.venv/
venv/

# Manim / generated media (never commit renders)
media/
**/media/
*.mp4
*.mov
*.wav
*.mp3

# DaVinci Resolve project backups (a .drp is never uploaded — deliverable is the .mov)
*.drp

# Manim snapshot cache (build artifact, 50+ MB pickles). Scoped to the
# animations tree so it does NOT touch the kept solver .pkl files in math/data/.
animations/**/cache/

# OS / editor junk
.DS_Store

# Claude config symlinks (machine-local; recreated from dotclaude by /sync-videos)
.claude/commands
.claude/settings.local.json

# Ignore generated math data by default
/math/data/*

# Keep precomputed lookup/cache files needed for imports
!/math/data/precomputed/
!/math/data/precomputed/**

# Keep reduced state files, useful for rebuilding/checking terminal shards
!/math/data/reduced_states/
!/math/data/reduced_states/**

# Keep current value/policy/property shards
!/math/data/state_properties/
!/math/data/state_properties/**

# Keep simplified one-turn transition kernels
!/math/data/turn_kernels/
!/math/data/turn_kernels/**

# Keep only the initial final outcome distribution
!/math/data/final_outcome_dists/
/math/data/final_outcome_dists/*
!/math/data/final_outcome_dists/level_00/
/math/data/final_outcome_dists/level_00/*
!/math/data/final_outcome_dists/level_00/0000000000000.npz

# Optional: keep old value-iteration pickle outputs only if you still use them.
# !/math/data/values/
# !/math/data/values/**

# Ignore notebook checkpoints
**/.ipynb_checkpoints/
